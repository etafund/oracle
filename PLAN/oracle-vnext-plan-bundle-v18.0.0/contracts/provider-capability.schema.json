    },
    "evidence_required": {
      "type": "boolean"
    },
    "next_command": {
      "type": ["string", "null"]
    },
    "provider": {
      "type": "string"
    },
    "remote_browser_supported": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "provider_capability.v1"
    },
    "status": {
